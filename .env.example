# Copy this file to .env and adjust values for your environment.

# Optional API settings used by custom tools.
VAR_API_KEY=
VAR_API_BASE_URL=

# Runtime transport mode: stdio, sse, or web (alias for sse).
MCP_TRANSPORT=stdio

# Tool exposure profile: minimal, canonical, or full.
DEVONTHINK_TOOL_PROFILE=canonical

# Optional live-test fixture UUIDs. Keep real local DEVONthink UUIDs in .env only.
DEVONTHINK_TEST_DATABASE_UUID=
DEVONTHINK_TEST_SCHOLAR_GROUP_UUID=
DEVONTHINK_TEST_CONCORDANCE_GROUP_UUID=
DEVONTHINK_TEST_ARCHIVE_GROUP_UUID=
DEVONTHINK_TEST_CHRONO_GROUP_UUID=
DEVONTHINK_TEST_CHAOS_GROUP_UUID=
DEVONTHINK_TEST_CHAOS_GROUP_NAME=
