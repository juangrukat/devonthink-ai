{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tin-canmcp.dev/schema/tools.schema.json",
  "title": "tools.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "name",
      "description",
      "group",
      "tier",
      "status",
      "canonical_tool",
      "overlap_family",
      "source_path",
      "catalog_path",
      "executable",
      "priority",
      "default_exposed",
      "accepted_identifiers",
      "preferred_identifier",
      "identifier_guidance",
      "safety_class",
      "supports_dry_run",
      "supports_plan",
      "supports_verify",
      "requires_confirmation",
      "mutation_scope",
      "signal_tier",
      "profile_availability",
      "prefer_when",
      "example"
    ],
    "properties": {
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "group": { "type": "string", "minLength": 1 },
      "tier": { "type": "string", "minLength": 1 },
      "status": { "type": "string", "minLength": 1 },
      "canonical_tool": { "type": "string", "minLength": 1 },
      "overlap_family": { "type": ["string", "null"] },
      "source_path": { "type": "string", "minLength": 1 },
      "catalog_path": { "type": "string", "minLength": 1 },
      "executable": { "type": "string", "minLength": 1 },
      "priority": { "type": "integer" },
      "default_exposed": { "type": "boolean" },
      "accepted_identifiers": { "type": "array", "items": { "type": "string" } },
      "preferred_identifier": { "type": ["string", "null"] },
      "identifier_guidance": { "type": "string", "minLength": 1 },
      "safety_class": {
        "type": "string",
        "enum": [
          "read_only",
          "analysis_only",
          "writes_metadata",
          "writes_content",
          "moves_records",
          "creates_records",
          "communication_write",
          "bulk_write",
          "maintenance_write",
          "destructive",
          "arbitrary_applescript"
        ]
      },
      "supports_dry_run": { "type": "boolean" },
      "supports_plan": { "type": "boolean" },
      "supports_verify": { "type": "boolean" },
      "requires_confirmation": { "type": "boolean" },
      "mutation_scope": {
        "type": "string",
        "enum": ["none", "single_record", "batch", "database", "system"]
      },
      "signal_tier": {
        "type": "string",
        "enum": ["authoritative", "structural", "inferred"]
      },
      "profile_availability": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
      "prefer_when": { "type": "string", "minLength": 1 },
      "degradation_contract": { "type": ["string", "null"] },
      "example": { "type": "string", "minLength": 1 },
      "source_variants": { "type": "array", "items": { "type": "string" } },
      "tags": { "type": "array", "items": { "type": "string" } },
      "input_schema": { "type": "object" },
      "invocation_pitfalls": { "type": "array", "items": { "type": "string" } }
    },
    "additionalProperties": true
  }
}
